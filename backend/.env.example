# NexusAir Backend — Environment Variables
# Copy this file to .env and adjust values for your setup.
# All values shown are the defaults — only override what you need.

# ── Server ────────────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8765

# ── LLM Model ─────────────────────────────────────────────────────────────────
# Filename of the GGUF model inside data/llm_models/
# Run download_model.py to download a compatible model.
DEFAULT_MODEL=Phi-3-mini-4k-instruct-q4.gguf

# ── Embedding Model ───────────────────────────────────────────────────────────
# HuggingFace model ID — will be cached locally after first download.
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Retrieval Hyper-parameters ────────────────────────────────────────────────
RRF_K=60
TOP_K=20
TOP_N=8
MAX_CONTEXT_TOKENS=2048
GRAPH_HOP_DEPTH=2

# ── Ingest ────────────────────────────────────────────────────────────────────
PDF_CHUNK_SIZE=2000
MAX_FILE_SIZE_MB=50

# ── Debug / Development ───────────────────────────────────────────────────────
# Set to True to enable SQLAlchemy SQL logging and uvicorn reload.
# NEVER set True in a packaged production build.
DEBUG_MODE=False
