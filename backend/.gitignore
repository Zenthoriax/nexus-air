# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
sdist/
wheels/
*.whl
MANIFEST

# ─── Virtual Environments ─────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env.local
.env.*.local

# ─── Environment & Secrets ────────────────────────────────────────────────────
.env
