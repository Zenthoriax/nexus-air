alembic/versions/__pycache__/

# ─── ML / Embedding Models ────────────────────────────────────────────────────
# sentence-transformers and HuggingFace cache large model files
models/
*.bin
*.safetensors
*.onnx
*.pt
*.pth
*.gguf
.cache/
huggingface/

# ─── Testing ──────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
pytest_output.txt
*.log

# ─── IDEs & Editors ───────────────────────────────────────────────────────────
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
*.swp
*~

# ─── OS Generated ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

